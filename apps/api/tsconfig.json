{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "bundler",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "../../",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "forceConsistentCasingInFileNames": false,
    "paths": {
      "@seltra/ai": ["../../packages/ai/src/index.ts"],
      "@seltra/ai/*": ["../../packages/ai/src/*"],
      "@seltra/db": ["../../packages/db/src/index.ts"],
      "@seltra/db/*": ["../../packages/db/src/*"],
      "@seltra/types": ["../../packages/types/src/index.ts"],
      "@seltra/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/ai/src/**/*",
    "../../packages/db/src/**/*",
    "../../packages/types/src/**/*"
  ]
}